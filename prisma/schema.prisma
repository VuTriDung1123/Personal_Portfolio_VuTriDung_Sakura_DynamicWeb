generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Post {
  // Giữ nguyên uuid() của cấu trúc cũ để không bị lỗi ID
  id        String   @id @default(uuid()) 
  
  // Ánh xạ (Map) dữ liệu cột cũ sang trường mới
  titleVi   String   @map("title")
  titleEn   String   @default("")
  titleJp   String   @default("")
  
  contentVi String   @db.Text @map("content")
  contentEn String   @db.Text @default("")
  contentJp String   @db.Text @default("")
  
  tag       String?
  images    String   @default("[]")
  createdAt DateTime @default(now())
}

model PageSection {
  id          String   @id @default(uuid())
  sectionKey  String   @unique 
  contentEn   String   @db.Text
  contentVi   String   @db.Text
  contentJp   String   @db.Text
  updatedAt   DateTime @updatedAt
}